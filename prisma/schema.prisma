// S5Evo — Relationales Datenmodell v2
// Prisma + PostgreSQL (Prisma Postgres)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Role {
  ADMIN
  MODERATOR
  ZEITNAHME
  TEAMCHEF
  TEILNEHMER
}

enum DashboardLayoutScope {
  PERSONAL
  GLOBAL
}

enum DashboardKey {
  TEAM_DASHBOARD
}

enum CompetitionStatus {
  DRAFT
  OPEN
  RUNNING
  CLOSED
}

enum DisciplineCode {
  RUN
  BENCH
  STOCK
  ROAD
  MTB
}

enum DisciplineAssignment {
  RUN
  BENCH
  STOCK
  ROAD
  MTB
  TBD
}

enum SortOrder {
  ASC
  DESC
}

enum DisciplineType {
  SIMPLE
  SHOTS
}

enum ClassificationType {
  AGE_INDIVIDUAL
  AGE_TEAM
  COMBINED
}

enum Gender {
  MALE
  FEMALE
}

enum GenderRestriction {
  FEMALE_ONLY
}

enum BenchPressMode {
  GROSS
  NETTO
}

enum ApprovalStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum ResultDataSource {
  LEGACY_IMPORT
  TIMEKEEPING_SYNC
  MANUAL_ADMIN
  SYSTEM_RECALC
}

enum ResultDataPurpose {
  PRODUCTION
  PROD_TEST
  DRY_RUN
}

enum ResultDataBatchStatus {
  STAGED
  VALIDATED
  REVIEWED
  PUBLISHED
  DISCARDED
  ERROR
}

enum ResultValidationStatus {
  PENDING
  VALID
  WARNING
  ERROR
}

enum ResultDraftStatus {
  DRAFT
  VALIDATED
  CONFLICT
  APPROVED
  REJECTED
  PUBLISHED
  DISCARDED
}

enum ResultConflictStatus {
  UNCHECKED
  NONE
  CONFLICT
}

enum ResultPublicationStatus {
  PUBLISHED
  REVERTED
}

enum ResultPublicationAction {
  UPSERT
  DELETE
}

enum ResultResetScope {
  RAW_BATCH
  DRAFTS
  PUBLICATION
  OFFICIAL_RESULTS
  TEST_DATA
}

enum ResultResetMode {
  PREVIEW
  EXECUTED
}

enum ParticipantAuditAction {
  REQUEST_SUBMITTED
  REQUEST_UPDATED
  REQUEST_APPROVED
  REQUEST_REJECTED
  DIRECT_CHANGE
}

enum ChangeRequestStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  APPLIED
}

enum ChangeRequestTargetType {
  PARTICIPANT
  TEAM
  USER
  CONTRACT
  METERING_POINT
}

enum ChangeRequestChangeType {
  UPDATE
  DELETE
  RESTORE
  ROLE_CHANGE
}

enum ChangeRequestSource {
  SELF_SERVICE
  ADMIN
  IMPORT
  SYSTEM
}

enum ChangeRequestAuditAction {
  CREATED
  UPDATED
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
  APPLIED
  FAILED
}

enum PendingChangeBundleType {
  SWAP
}

enum PendingChangeBundleStatus {
  PENDING
  APPROVED
  REJECTED
  CONFLICT
}

enum LegacySyncStatus {
  OPEN
  LEGACY_OK
}

enum ShirtSize {
  K116
  K128
  K140
  K152
  K164
  XS
  S
  M
  L
  XL
  XXL
  XXXL
}

enum ChangelogEntryType {
  BUG
  REQUEST
}

enum ChangelogEntryStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum HomeNewsStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ClaimTokenExpiryMode {
  FIXED_DAYS
  REGISTRATION_DEADLINE
  COMPETITION_END
}

enum TeamPublicationLevel {
  TEAM_ANONYM
  TEAMNAME_OEFFENTLICH
  ALLES_OEFFENTLICH
}

enum ParticipantPublicationPreference {
  NAME_VERBERGEN
  NAME_VEROEFFENTLICHEN
}

enum TeamMemberRoleType {
  TEAM_MANAGER
}

enum TeamRegistrationMode {
  TEAM
  MARKETPLACE
}

enum MarketplaceVisibility {
  PUBLIC
  MARKETPLACE_USERS
  PORTAL_USERS
  ADMIN_MANAGEMENT_ONLY
}

enum MarketplaceGlobalVisibility {
  SELECTIVE
  OFFLINE
}

enum LivePublicationVisibility {
  ADMINS
  PORTAL_USERS
  SPECTATORS
}

enum MarketplaceStatus {
  NEW
  REVIEWED
  MATCHING
  MATCHED
  WITHDRAWN
}

enum ConversationType {
  SUPPORT
  TEAM
  DIRECT
  GROUP
  SYSTEM
}

enum ConversationStatus {
  OPEN
  WAITING_FOR_ADMIN
  WAITING_FOR_USER
  CLOSED
}

enum ConversationParticipantRole {
  OWNER
  MEMBER
  ADMIN
  MODERATOR
  READ_ONLY
}

enum MessageContentFormat {
  PLAIN
  ENCRYPTED
}

enum MessageSenderDisplayMode {
  PERSONAL
  ORG
}

enum ConsentCategory {
  FUNCTIONAL_STORAGE
  EXTERNAL_MAPS
  LOCAL_OFFLINE
  PORTAL_MESSAGE_EMAIL
}

enum ConsentSource {
  BANNER
  SETTINGS
  PROFILE
  REGISTRATION
  CLAIM
  ADMIN
}

// ==================== TENANT ====================

model Tenant {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  primaryColor      String   @default("#dc2626")
  logoUrl           String?
  heroImageUrl      String?
  contactEmail      String?
  website           String?
  privacyText       String?
  defaultTheme      String   @default("DARK")
  claimLinksEnabled Boolean  @default(true)
  publicPortalRegistrationEnabled Boolean @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  competitions         Competition[]
  tenantRoles          TenantRole[]
  changeRequests       ChangeRequest[]
  resetSnapshots       CompetitionResetSnapshot[]
  auditEvents          AuditEvent[]
  dashboardLayouts     DashboardLayout[]
  conversations        Conversation[]
  timekeepingSessions  TimekeepingSession[]
  timekeepingEvents    TimekeepingEvent[]
  resultDataBatches    ResultDataBatch[]
  resultRawRecords     ResultRawRecord[]
  resultDrafts         ResultDraft[]
  resultPublications   ResultPublication[]
  resultResetSnapshots ResultResetSnapshot[]
  homeNewsEntries      HomeNewsEntry[]
  consentPreferences   ConsentPreference[]

  @@map("tenants")
}

// ==================== USER ====================

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  image        String?
  authentikSub String?   @unique
  lastSeenAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  // Relations
  tenantRoles                 TenantRole[]
  ownedTeams                  Team[]                     @relation("TeamOwner")
  chiefOfTeams                Team[]                     @relation("TeamChief")
  teamMemberRoles             TeamMemberRole[]           @relation("TeamMemberRoleUser")
  teamMemberRolesGranted      TeamMemberRole[]           @relation("TeamMemberRoleGrantedBy")
  teamMemberRolesRevoked      TeamMemberRole[]           @relation("TeamMemberRoleRevokedBy")
  linkedParticipants          Participant[]              @relation("ParticipantUser")
  requestedChanges            PendingChange[]            @relation("ChangeRequester")
  reviewedChanges             PendingChange[]            @relation("ChangeReviewer")
  changeRequestsRequested     ChangeRequest[]            @relation("ChangeRequestRequester")
  changeRequestsReviewed      ChangeRequest[]            @relation("ChangeRequestReviewer")
  changeRequestsApplied       ChangeRequest[]            @relation("ChangeRequestApplier")
  changeRequestAuditLogs      ChangeRequestAuditLog[]    @relation("ChangeRequestAuditActor")
  participantAuditLogs        ParticipantAuditLog[]      @relation("ParticipantAuditActor")
  changelogEntriesCreated     ChangelogEntry[]           @relation("EntryCreator")
  changelogEntriesResolved    ChangelogEntry[]           @relation("EntryResolver")
  homeNewsEntriesCreated      HomeNewsEntry[]             @relation("HomeNewsEntryCreator")
  homeNewsEntriesUpdated      HomeNewsEntry[]             @relation("HomeNewsEntryUpdater")
  claimedRegistrationTokens   RegistrationClaimToken[]   @relation("ClaimedRegistrationTokens")
  claimedParticipantTokens    ParticipantClaimToken[]    @relation("ClaimedParticipantTokens")
  resetSnapshotsCreated       CompetitionResetSnapshot[] @relation("CompetitionResetSnapshotCreator")
  auditEventsCreated          AuditEvent[]               @relation("AuditEventActor")
  dashboardLayoutsOwned       DashboardLayout[]          @relation("DashboardLayoutOwner")
  dashboardLayoutsCreated     DashboardLayout[]          @relation("DashboardLayoutCreator")
  dashboardLayoutsUpdated     DashboardLayout[]          @relation("DashboardLayoutUpdater")
  conversationsCreated        Conversation[]             @relation("ConversationCreator")
  conversationsClosed         Conversation[]             @relation("ConversationCloser")
  conversationParticipants    ConversationParticipant[]
  messagesSent                Message[]                  @relation("MessageSender")
  consentPreferences          ConsentPreference[]        @relation("ConsentPreferenceUser")
  timekeepingSessionsCreated  TimekeepingSession[]       @relation("TimekeepingSessionCreator")
  timekeepingEventsCreated    TimekeepingEvent[]         @relation("TimekeepingEventActor")
  resultDataBatchesCreated    ResultDataBatch[]          @relation("ResultDataBatchCreator")
  resultDataBatchesReviewed   ResultDataBatch[]          @relation("ResultDataBatchReviewer")
  resultPublicationsCreated   ResultPublication[]        @relation("ResultPublicationCreator")
  resultResetSnapshotsCreated ResultResetSnapshot[]      @relation("ResultResetSnapshotCreator")

  @@index([lastSeenAt])
  @@map("users")
}

// ==================== TENANT ROLE ====================

model TenantRole {
  id        String   @id @default(cuid())
  role      Role
  createdAt DateTime @default(now())

  // Relations
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId, role])
  @@index([tenantId, role])
  @@map("tenant_roles")
}

// ==================== COMPETITION ====================

model Competition {
  id                                String                      @id @default(cuid())
  name                              String
  year                              Int
  date                              DateTime?
  dateEnd                           DateTime?
  registrationDeadline              DateTime?
  claimTokenExpiryMode              ClaimTokenExpiryMode        @default(COMPETITION_END)
  claimTokenTtlDays                 Int                         @default(7)
  teamOwnerFilterVisibleForTeamchef Boolean                     @default(false)
  participantsCanViewAllTeams       Boolean                     @default(false)
  spectatorsCanViewAllTeams         Boolean                     @default(false)
  hideForeignTeams                  Boolean                     @default(false)
  liveTeamsVisibility               LivePublicationVisibility   @default(ADMINS)
  liveStartlistsVisibility          LivePublicationVisibility   @default(ADMINS)
  marketplaceGlobalVisibility       MarketplaceGlobalVisibility @default(SELECTIVE)
  registrationNotificationEmail     String?
  shirtOrderDeadline                DateTime?
  status                            CompetitionStatus           @default(DRAFT)
  maxTeams                          Int?
  teamSize                          Int                         @default(5)
  ageReferenceDate                  DateTime?
  benchPressTara                    Float                       @default(20.0)
  benchPressMode                    BenchPressMode              @default(GROSS)
  stockShotsCount                   Int                         @default(11)
  stockStrikeoutCount               Int                         @default(1)
  location                          String?
  publicResults                     Boolean                     @default(true)
  createdAt                         DateTime                    @default(now())
  updatedAt                         DateTime                    @updatedAt

  // Relations
  tenantId             String
  tenant               Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teams                Team[]
  disciplines          Discipline[]
  classifications      Classification[]
  changeRequests       ChangeRequest[]
  resetSnapshots       CompetitionResetSnapshot[]
  auditEvents          AuditEvent[]
  dashboardLayouts     DashboardLayout[]
  conversations        Conversation[]
  timekeepingSessions  TimekeepingSession[]
  timekeepingEvents    TimekeepingEvent[]
  resultDataBatches    ResultDataBatch[]
  resultRawRecords     ResultRawRecord[]
  resultDrafts         ResultDraft[]
  resultPublications   ResultPublication[]
  resultResetSnapshots ResultResetSnapshot[]
  homeNewsEntries      HomeNewsEntry[]
  consentPreferences   ConsentPreference[]

  @@index([tenantId, status, year, createdAt])
  @@index([status, year, createdAt])
  @@map("competitions")
}

model DashboardLayout {
  id            String               @id @default(cuid())
  dashboardKey  DashboardKey
  scope         DashboardLayoutScope
  name          String
  configVersion Int                  @default(1)
  config        Json
  isDefault     Boolean              @default(false)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  deletedAt     DateTime?

  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  competitionId String?
  competition   Competition? @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  ownerId       String?
  owner         User?        @relation("DashboardLayoutOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdById   String
  createdBy     User         @relation("DashboardLayoutCreator", fields: [createdById], references: [id])
  updatedById   String?
  updatedBy     User?        @relation("DashboardLayoutUpdater", fields: [updatedById], references: [id])

  @@index([tenantId, dashboardKey, scope, deletedAt])
  @@index([ownerId, dashboardKey, deletedAt])
  @@index([competitionId])
  @@index([isDefault])
  @@map("dashboard_layouts")
}

// ==================== TEAM ====================

model Team {
  id                    String                @id @default(cuid())
  name                  String
  startNumber           String?
  contactName           String?
  contactEmail          String?
  contactPhone          String?
  clubName              String?
  notes                 String?
  teamPublicationLevel  TeamPublicationLevel  @default(TEAM_ANONYM)
  registrationMode      TeamRegistrationMode  @default(TEAM)
  marketplaceVisibility MarketplaceVisibility @default(ADMIN_MANAGEMENT_ONLY)
  marketplaceStatus     MarketplaceStatus     @default(NEW)
  marketplaceMessage    String?
  approved              Boolean               @default(false)
  totalAge              Int?
  classificationCode    String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  deletedAt             DateTime?

  // Relations
  competitionId           String
  competition             Competition              @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  ownerId                 String
  owner                   User                     @relation("TeamOwner", fields: [ownerId], references: [id])
  teamChiefId             String?
  teamChief               User?                    @relation("TeamChief", fields: [teamChiefId], references: [id])
  memberRoles             TeamMemberRole[]
  participants            Participant[]
  rankings                CompetitionRanking[]
  registrationClaimTokens RegistrationClaimToken[]
  conversations           Conversation[]

  @@index([competitionId, deletedAt])
  @@index([ownerId, deletedAt])
  @@index([teamChiefId, deletedAt])
  @@index([registrationMode, marketplaceStatus])
  @@index([marketplaceVisibility])
  @@index([startNumber])
  @@index([contactEmail])
  @@index([updatedAt])
  @@map("teams")
}

model TeamMemberRole {
  id        String             @id @default(cuid())
  role      TeamMemberRoleType @default(TEAM_MANAGER)
  reason    String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  revokedAt DateTime?

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("TeamMemberRoleUser", fields: [userId], references: [id], onDelete: Cascade)

  grantedByUserId String?
  grantedByUser   User?   @relation("TeamMemberRoleGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)

  revokedByUserId String?
  revokedByUser   User?   @relation("TeamMemberRoleRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  @@unique([teamId, userId, role])
  @@index([userId, role, revokedAt])
  @@index([teamId, role, revokedAt])
  @@map("team_member_roles")
}

model RegistrationClaimToken {
  id             String    @id @default(cuid())
  tokenHash      String    @unique
  suggestedEmail String
  suggestedName  String?
  createdAt      DateTime  @default(now())
  expiresAt      DateTime
  claimedAt      DateTime?
  revokedAt      DateTime?

  teamId          String
  team            Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  claimedByUserId String?
  claimedByUser   User?   @relation("ClaimedRegistrationTokens", fields: [claimedByUserId], references: [id])

  @@index([teamId])
  @@index([suggestedEmail])
  @@map("registration_claim_tokens")
}

model RegistrationClaimAuditEvent {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  eventType    String
  outcome      String?
  reason       String?
  suspicious   Boolean  @default(false)
  ipAddress    String?
  userAgent    String?
  sessionEmail String?
  tokenId      String?
  teamId       String?
  userId       String?

  @@index([createdAt])
  @@index([tokenId])
  @@index([teamId])
  @@index([ipAddress])
  @@index([suspicious])
  @@map("registration_claim_audit_events")
}

model ParticipantClaimToken {
  id             String    @id @default(cuid())
  tokenHash      String    @unique
  suggestedEmail String
  suggestedName  String?
  createdAt      DateTime  @default(now())
  expiresAt      DateTime
  claimedAt      DateTime?
  revokedAt      DateTime?

  participantId   String
  participant     Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  claimedByUserId String?
  claimedByUser   User?       @relation("ClaimedParticipantTokens", fields: [claimedByUserId], references: [id])

  @@index([participantId])
  @@index([suggestedEmail])
  @@map("participant_claim_tokens")
}

model ParticipantClaimAuditEvent {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  eventType     String
  outcome       String?
  reason        String?
  suspicious    Boolean  @default(false)
  ipAddress     String?
  userAgent     String?
  sessionEmail  String?
  tokenId       String?
  participantId String?
  teamId        String?
  userId        String?

  @@index([createdAt])
  @@index([tokenId])
  @@index([participantId])
  @@index([teamId])
  @@index([ipAddress])
  @@index([suspicious])
  @@map("participant_claim_audit_events")
}

// ==================== PARTICIPANT ====================

model Participant {
  id                               String                           @id @default(cuid())
  firstName                        String
  lastName                         String
  birthYear                        Int
  birthDate                        String?
  gender                           Gender
  disciplineCode                   DisciplineAssignment             @default(TBD)
  marketplaceReturnTeamId          String?
  marketplaceReturnDisciplineCode  DisciplineAssignment?
  participantPublicationPreference ParticipantPublicationPreference @default(NAME_VERBERGEN)
  shirtSize                        ShirtSize?
  moderationNote                   String?
  consentGiven                     Boolean                          @default(false)
  email                            String?
  phone                            String?
  overallRank                      Int?
  overallPoints                    Int?
  createdAt                        DateTime                         @default(now())
  updatedAt                        DateTime                         @updatedAt
  deletedAt                        DateTime?

  // Relations
  userId         String?
  user           User?                   @relation("ParticipantUser", fields: [userId], references: [id], onDelete: SetNull)
  teamId         String
  team           Team                    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  claimTokens    ParticipantClaimToken[]
  results        DisciplineResult[]
  pendingChanges PendingChange[]
  auditLogs      ParticipantAuditLog[]
  conversations  Conversation[]
  consentPreferences ConsentPreference[] @relation("ConsentPreferenceParticipant")

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([teamId, deletedAt])
  @@index([marketplaceReturnTeamId])
  @@index([lastName, firstName])
  @@map("participants")
}

model ConsentPreference {
  id            String          @id @default(cuid())
  category      ConsentCategory
  granted       Boolean         @default(false)
  noticeVersion String
  source        ConsentSource   @default(BANNER)
  grantedAt     DateTime?
  withdrawnAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  userId        String?
  user          User?           @relation("ConsentPreferenceUser", fields: [userId], references: [id], onDelete: Cascade)
  participantId String?
  participant   Participant?    @relation("ConsentPreferenceParticipant", fields: [participantId], references: [id], onDelete: Cascade)
  tenantId      String?
  tenant        Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  competitionId String?
  competition   Competition?    @relation(fields: [competitionId], references: [id], onDelete: SetNull)

  @@unique([userId, category])
  @@unique([participantId, category])
  @@index([tenantId, category])
  @@index([competitionId, category])
  @@index([category, granted])
  @@map("consent_preferences")
}

// ==================== MESSAGING ====================

model Conversation {
  id            String             @id @default(cuid())
  type          ConversationType   @default(SUPPORT)
  status        ConversationStatus @default(OPEN)
  subject       String
  lastMessageAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  closedAt      DateTime?
  deletedAt     DateTime?

  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  competitionId String?
  competition   Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  teamId        String?
  team          Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  participantId String?
  participant   Participant? @relation(fields: [participantId], references: [id], onDelete: SetNull)
  createdById   String
  createdBy     User         @relation("ConversationCreator", fields: [createdById], references: [id], onDelete: Cascade)
  closedById    String?
  closedBy      User?        @relation("ConversationCloser", fields: [closedById], references: [id], onDelete: SetNull)

  participants ConversationParticipant[]
  messages     Message[]

  @@index([tenantId, type, status, lastMessageAt])
  @@index([competitionId, type, status])
  @@index([teamId])
  @@index([participantId])
  @@index([createdById])
  @@map("conversations")
}

model ConversationParticipant {
  id         String                      @id @default(cuid())
  role       ConversationParticipantRole @default(MEMBER)
  joinedAt   DateTime                    @default(now())
  leftAt     DateTime?
  lastReadAt DateTime?
  mutedAt    DateTime?

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, leftAt])
  @@index([conversationId, role])
  @@map("conversation_participants")
}

model Message {
  id                String                   @id @default(cuid())
  contentFormat     MessageContentFormat     @default(PLAIN)
  senderDisplayMode MessageSenderDisplayMode @default(PERSONAL)
  body              String?
  bodyCiphertext    String?
  bodyPreview       String?
  encryptionVersion Int?
  keyId             String?
  createdAt         DateTime                 @default(now())
  editedAt          DateTime?
  deletedAt         DateTime?

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
  @@map("messages")
}

// ==================== DISCIPLINE ====================

model Discipline {
  id        String         @id @default(cuid())
  code      DisciplineCode
  name      String
  unit      String
  sortOrder SortOrder
  type      DisciplineType

  // Relations
  competitionId String
  competition   Competition        @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  results       DisciplineResult[]

  @@unique([competitionId, code])
  @@map("disciplines")
}

// ==================== DISCIPLINE RESULT ====================

model DisciplineResult {
  id        String   @id @default(cuid())
  rawValue  Float?
  rank      Int?
  points    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  disciplineId  String
  discipline    Discipline  @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  shots         Shot[]

  @@unique([disciplineId, participantId])
  @@index([participantId])
  @@map("discipline_results")
}

// ==================== SHOT (Stockschießen) ====================

model Shot {
  id          String  @id @default(cuid())
  shotNumber  Int
  value       Int
  isStrikeout Boolean @default(false)

  // Relations
  resultId String
  result   DisciplineResult @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@unique([resultId, shotNumber])
  @@map("shots")
}

// ==================== CLASSIFICATION ====================

model Classification {
  id                String             @id @default(cuid())
  code              String
  name              String
  type              ClassificationType
  minAge            Int?
  maxAge            Int?
  genderRestriction GenderRestriction?
  sourceClassCodes  String[]

  // Relations
  competitionId String
  competition   Competition          @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  rankings      CompetitionRanking[]

  @@unique([competitionId, code])
  @@map("classifications")
}

// ==================== COMPETITION RANKING ====================

model CompetitionRanking {
  id          String @id @default(cuid())
  totalPoints Int    @default(0)
  rank        Int    @default(0)

  // Relations
  classificationId String
  classification   Classification @relation(fields: [classificationId], references: [id], onDelete: Cascade)
  teamId           String
  team             Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([classificationId, teamId])
  @@index([teamId])
  @@map("competition_rankings")
}

// ==================== PENDING CHANGE (Approval-Workflow) ====================

model PendingChange {
  id            String                     @id @default(cuid())
  changeData    String
  beforeData    String?
  status        ApprovalStatus             @default(DRAFT)
  legacyStatus  LegacySyncStatus           @default(OPEN)
  bundleId      String?
  bundleType    PendingChangeBundleType?
  bundleStatus  PendingChangeBundleStatus?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  reviewedAt    DateTime?
  reviewComment String?

  // Relations
  participantId String
  participant   Participant           @relation(fields: [participantId], references: [id], onDelete: Cascade)
  requestedById String
  requestedBy   User                  @relation("ChangeRequester", fields: [requestedById], references: [id])
  reviewedById  String?
  reviewedBy    User?                 @relation("ChangeReviewer", fields: [reviewedById], references: [id])
  auditLogs     ParticipantAuditLog[]

  @@index([status, updatedAt])
  @@index([participantId, status])
  @@index([requestedById, status])
  @@index([bundleId])
  @@index([bundleStatus, updatedAt])
  @@index([legacyStatus, updatedAt])
  @@map("pending_changes")
}

model ParticipantAuditLog {
  id         String                 @id @default(cuid())
  action     ParticipantAuditAction
  beforeData String?
  afterData  String?
  message    String?
  legacyStatus LegacySyncStatus     @default(OPEN)
  createdAt  DateTime               @default(now())

  participantId   String
  participant     Participant    @relation(fields: [participantId], references: [id], onDelete: Cascade)
  actorId         String?
  actor           User?          @relation("ParticipantAuditActor", fields: [actorId], references: [id])
  pendingChangeId String?
  pendingChange   PendingChange? @relation(fields: [pendingChangeId], references: [id], onDelete: SetNull)

  @@index([participantId, createdAt])
  @@index([pendingChangeId])
  @@index([legacyStatus, createdAt])
  @@map("participant_audit_logs")
}

// ==================== GENERIC CHANGE REQUEST (Approval-Workflow v2) ====================

model ChangeRequest {
  id                String                  @id @default(cuid())
  targetType        ChangeRequestTargetType
  targetId          String
  changeType        ChangeRequestChangeType @default(UPDATE)
  status            ChangeRequestStatus     @default(DRAFT)
  legacyStatus      LegacySyncStatus        @default(OPEN)
  source            ChangeRequestSource     @default(SELF_SERVICE)
  beforeSnapshot    Json?
  requestedSnapshot Json
  metadata          Json?
  priority          Int                     @default(0)
  reviewComment     String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  submittedAt       DateTime?
  reviewedAt        DateTime?
  appliedAt         DateTime?

  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  competitionId String?
  competition   Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)

  requestedById String
  requestedBy   User    @relation("ChangeRequestRequester", fields: [requestedById], references: [id])
  reviewedById  String?
  reviewedBy    User?   @relation("ChangeRequestReviewer", fields: [reviewedById], references: [id])
  appliedById   String?
  appliedBy     User?   @relation("ChangeRequestApplier", fields: [appliedById], references: [id])

  supersedesRequestId String?
  supersedesRequest   ChangeRequest?  @relation("ChangeRequestSupersession", fields: [supersedesRequestId], references: [id], onDelete: SetNull)
  supersededBy        ChangeRequest[] @relation("ChangeRequestSupersession")

  auditLogs ChangeRequestAuditLog[]

  @@index([tenantId, status, updatedAt])
  @@index([competitionId, status, updatedAt])
  @@index([targetType, targetId, status])
  @@index([requestedById, status])
  @@index([reviewedById, status])
  @@index([legacyStatus, updatedAt])
  @@map("change_requests")
}

model ChangeRequestAuditLog {
  id         String                   @id @default(cuid())
  action     ChangeRequestAuditAction
  beforeData Json?
  afterData  Json?
  message    String?
  createdAt  DateTime                 @default(now())

  changeRequestId String
  changeRequest   ChangeRequest @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)
  actorId         String?
  actor           User?         @relation("ChangeRequestAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([changeRequestId, createdAt])
  @@index([actorId, createdAt])
  @@map("change_request_audit_logs")
}

model CompetitionResetSnapshot {
  id        String   @id @default(cuid())
  reason    String
  summary   Json
  snapshot  Json
  createdAt DateTime @default(now())

  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  createdById   String?
  createdBy     User?       @relation("CompetitionResetSnapshotCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([competitionId, createdAt])
  @@map("competition_reset_snapshots")
}

model AuditEvent {
  id         String   @id @default(cuid())
  action     String
  scopeType  String
  scopeId    String
  entityType String?
  entityId   String?
  reason     String?
  beforeData Json?
  afterData  Json?
  meta       Json?
  createdAt  DateTime @default(now())

  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  competitionId String?
  competition   Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  actorId       String?
  actor         User?        @relation("AuditEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([competitionId, createdAt])
  @@index([scopeType, scopeId, createdAt])
  @@index([action, createdAt])
  @@map("audit_events")
}

model TimekeepingSession {
  id                   String         @id @default(cuid())
  deviceId             String
  deviceName           String?
  disciplineCode       DisciplineCode
  startBlockName       String
  firstStartNumber     Int?
  startIntervalSeconds Int            @default(30)
  manualStartedAt      DateTime?
  status               String         @default("ACTIVE")
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  tenantId      String
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  competitionId String
  competition   Competition        @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  createdById   String?
  createdBy     User?              @relation("TimekeepingSessionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  events        TimekeepingEvent[]

  @@index([tenantId, competitionId, disciplineCode, status])
  @@index([deviceId, updatedAt])
  @@map("timekeeping_sessions")
}

model TimekeepingEvent {
  id            String   @id @default(cuid())
  clientEventId String
  eventType     String
  recordedAt    DateTime
  capturedAt    DateTime @default(now())
  startNumber   String?
  rawElapsedMs  Int?
  netElapsedMs  Int?
  note          String?
  payload       Json?
  createdAt     DateTime @default(now())

  sessionId     String
  session       TimekeepingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tenantId      String
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  competitionId String
  competition   Competition        @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  actorId       String?
  actor         User?              @relation("TimekeepingEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@unique([sessionId, clientEventId])
  @@index([tenantId, competitionId, recordedAt])
  @@index([competitionId, eventType, recordedAt])
  @@index([startNumber])
  @@map("timekeeping_events")
}

model ResultDataBatch {
  id                String                @id @default(cuid())
  source            ResultDataSource
  purpose           ResultDataPurpose     @default(PRODUCTION)
  status            ResultDataBatchStatus @default(STAGED)
  label             String?
  externalRef       String?
  sourceVersion     String?
  payload           Json?
  summary           Json?
  validationSummary Json?
  stagedAt          DateTime              @default(now())
  reviewedAt        DateTime?
  publishedAt       DateTime?
  discardedAt       DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  createdById   String?
  createdBy     User?       @relation("ResultDataBatchCreator", fields: [createdById], references: [id], onDelete: SetNull)
  reviewedById  String?
  reviewedBy    User?       @relation("ResultDataBatchReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  rawRecords     ResultRawRecord[]
  drafts         ResultDraft[]
  publications   ResultPublication[]
  resetSnapshots ResultResetSnapshot[]

  @@index([tenantId, competitionId, source, status])
  @@index([competitionId, purpose, status, createdAt])
  @@index([externalRef])
  @@map("result_data_batches")
}

model ResultRawRecord {
  id                 String                 @id @default(cuid())
  rowKey             String
  disciplineCode     DisciplineCode?
  startNumber        String?
  participantId      String?
  teamId             String?
  rawValue           Float?
  rawValueText       String?
  recordedAt         DateTime?
  payload            Json
  validationStatus   ResultValidationStatus @default(PENDING)
  validationMessages Json?
  createdAt          DateTime               @default(now())

  batchId       String
  batch         ResultDataBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  competitionId String
  competition   Competition     @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  drafts ResultDraft[]

  @@unique([batchId, rowKey])
  @@index([tenantId, competitionId, disciplineCode])
  @@index([competitionId, startNumber])
  @@index([participantId])
  @@map("result_raw_records")
}

model ResultDraft {
  id                     String               @id @default(cuid())
  status                 ResultDraftStatus    @default(DRAFT)
  conflictStatus         ResultConflictStatus @default(UNCHECKED)
  disciplineCode         DisciplineCode
  participantId          String?
  teamId                 String?
  startNumber            String?
  rawValue               Float?
  rawValueText           String?
  normalizedValue        Float?
  netElapsedMs           Int?
  timekeepingEventId     String?
  currentResultSnapshot  Json?
  proposedResultSnapshot Json?
  validationMessages     Json?
  reviewedAt             DateTime?
  publishedAt            DateTime?
  discardedAt            DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  batchId           String
  batch             ResultDataBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  sourceRawRecordId String?
  sourceRawRecord   ResultRawRecord? @relation(fields: [sourceRawRecordId], references: [id], onDelete: SetNull)
  tenantId          String
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  competitionId     String
  competition       Competition      @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  publicationItems ResultPublicationItem[]

  @@index([tenantId, competitionId, status, conflictStatus])
  @@index([competitionId, disciplineCode, participantId])
  @@index([competitionId, startNumber])
  @@index([timekeepingEventId])
  @@map("result_drafts")
}

model ResultPublication {
  id          String                  @id @default(cuid())
  version     Int
  status      ResultPublicationStatus @default(PUBLISHED)
  label       String?
  summary     Json?
  publishedAt DateTime                @default(now())
  revertedAt  DateTime?
  createdAt   DateTime                @default(now())

  tenantId      String
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  competitionId String
  competition   Competition      @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  sourceBatchId String?
  sourceBatch   ResultDataBatch? @relation(fields: [sourceBatchId], references: [id], onDelete: SetNull)
  createdById   String?
  createdBy     User?            @relation("ResultPublicationCreator", fields: [createdById], references: [id], onDelete: SetNull)

  items          ResultPublicationItem[]
  resetSnapshots ResultResetSnapshot[]

  @@unique([competitionId, version])
  @@index([tenantId, competitionId, status, publishedAt])
  @@map("result_publications")
}

model ResultPublicationItem {
  id             String                  @id @default(cuid())
  action         ResultPublicationAction
  disciplineCode DisciplineCode
  participantId  String?
  teamId         String?
  startNumber    String?
  resultId       String?
  beforeData     Json?
  afterData      Json?
  createdAt      DateTime                @default(now())

  publicationId String
  publication   ResultPublication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  draftId       String?
  draft         ResultDraft?      @relation(fields: [draftId], references: [id], onDelete: SetNull)

  @@index([publicationId, disciplineCode])
  @@index([participantId])
  @@index([resultId])
  @@map("result_publication_items")
}

model ResultResetSnapshot {
  id          String           @id @default(cuid())
  scope       ResultResetScope
  mode        ResultResetMode  @default(PREVIEW)
  reason      String
  scopeFilter Json?
  summary     Json
  snapshot    Json
  executedAt  DateTime?
  createdAt   DateTime         @default(now())

  tenantId      String
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  competitionId String
  competition   Competition        @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  batchId       String?
  batch         ResultDataBatch?   @relation(fields: [batchId], references: [id], onDelete: SetNull)
  publicationId String?
  publication   ResultPublication? @relation(fields: [publicationId], references: [id], onDelete: SetNull)
  createdById   String?
  createdBy     User?              @relation("ResultResetSnapshotCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, competitionId, scope, createdAt])
  @@index([batchId])
  @@index([publicationId])
  @@map("result_reset_snapshots")
}

// ==================== CHANGELOG ENTRY ====================

model HomeNewsEntry {
  id          String         @id @default(cuid())
  title       String
  body        String
  status      HomeNewsStatus @default(DRAFT)
  publishedAt DateTime?
  archivedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  competitionId String?
  competition   Competition? @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  createdById   String
  createdBy     User         @relation("HomeNewsEntryCreator", fields: [createdById], references: [id])
  updatedById   String?
  updatedBy     User?        @relation("HomeNewsEntryUpdater", fields: [updatedById], references: [id])

  @@index([tenantId, status, archivedAt, publishedAt])
  @@index([competitionId, status, archivedAt, publishedAt])
  @@map("home_news_entries")
}

model ChangelogEntry {
  id          String               @id @default(cuid())
  type        ChangelogEntryType
  status      ChangelogEntryStatus @default(OPEN)
  description String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  resolvedAt  DateTime?

  createdById String
  createdBy   User   @relation("EntryCreator", fields: [createdById], references: [id], onDelete: Cascade)

  resolvedById String?
  resolvedBy   User?   @relation("EntryResolver", fields: [resolvedById], references: [id])

  @@index([status])
  @@index([type])
  @@map("changelog_entries")
}
