// S5Evo — Relationales Datenmodell v2
// Prisma + PostgreSQL (Prisma Postgres)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Role {
  ADMIN
  MODERATOR
  TEAMCHEF
  TEILNEHMER
}

enum CompetitionStatus {
  DRAFT
  OPEN
  RUNNING
  CLOSED
}

enum DisciplineCode {
  RUN
  BENCH
  STOCK
  ROAD
  MTB
}

enum DisciplineAssignment {
  RUN
  BENCH
  STOCK
  ROAD
  MTB
  TBD
}

enum SortOrder {
  ASC
  DESC
}

enum DisciplineType {
  SIMPLE
  SHOTS
}

enum ClassificationType {
  AGE_INDIVIDUAL
  AGE_TEAM
  COMBINED
}

enum Gender {
  MALE
  FEMALE
}

enum GenderRestriction {
  FEMALE_ONLY
}

enum BenchPressMode {
  GROSS
  NETTO
}

enum ApprovalStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum ParticipantAuditAction {
  REQUEST_SUBMITTED
  REQUEST_UPDATED
  REQUEST_APPROVED
  REQUEST_REJECTED
  DIRECT_CHANGE
}

enum ChangeRequestStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  APPLIED
}

enum ChangeRequestTargetType {
  PARTICIPANT
  TEAM
  USER
  CONTRACT
  METERING_POINT
}

enum ChangeRequestChangeType {
  UPDATE
  DELETE
  RESTORE
  ROLE_CHANGE
}

enum ChangeRequestSource {
  SELF_SERVICE
  ADMIN
  IMPORT
  SYSTEM
}

enum ChangeRequestAuditAction {
  CREATED
  UPDATED
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
  APPLIED
  FAILED
}

enum PendingChangeBundleType {
  SWAP
}

enum PendingChangeBundleStatus {
  PENDING
  APPROVED
  REJECTED
  CONFLICT
}

enum ShirtSize {
  K116
  K128
  K140
  K152
  K164
  XS
  S
  M
  L
  XL
  XXL
  XXXL
}

enum ChangelogEntryType {
  BUG
  REQUEST
}

enum ChangelogEntryStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum ClaimTokenExpiryMode {
  FIXED_DAYS
  REGISTRATION_DEADLINE
  COMPETITION_END
}

enum TeamPublicationLevel {
  TEAM_ANONYM
  TEAMNAME_OEFFENTLICH
  ALLES_OEFFENTLICH
}

enum ParticipantPublicationPreference {
  NAME_VERBERGEN
  NAME_VEROEFFENTLICHEN
}

enum TeamMemberRoleType {
  TEAM_MANAGER
}

enum TeamRegistrationMode {
  TEAM
  MARKETPLACE
}

enum MarketplaceVisibility {
  PUBLIC
  MARKETPLACE_USERS
  PORTAL_USERS
  ADMIN_MANAGEMENT_ONLY
}

enum MarketplaceGlobalVisibility {
  SELECTIVE
  OFFLINE
}

enum MarketplaceStatus {
  NEW
  REVIEWED
  MATCHING
  MATCHED
  WITHDRAWN
}

// ==================== TENANT ====================

model Tenant {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  primaryColor      String   @default("#dc2626")
  logoUrl           String?
  heroImageUrl      String?
  contactEmail      String?
  website           String?
  privacyText       String?
  defaultTheme      String   @default("DARK")
  claimLinksEnabled Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  competitions   Competition[]
  tenantRoles    TenantRole[]
  changeRequests ChangeRequest[]
  resetSnapshots CompetitionResetSnapshot[]
  auditEvents    AuditEvent[]

  @@map("tenants")
}

// ==================== USER ====================

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  image        String?
  authentikSub String?   @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  // Relations
  tenantRoles               TenantRole[]
  ownedTeams                Team[]                     @relation("TeamOwner")
  chiefOfTeams              Team[]                     @relation("TeamChief")
  teamMemberRoles           TeamMemberRole[]           @relation("TeamMemberRoleUser")
  teamMemberRolesGranted    TeamMemberRole[]           @relation("TeamMemberRoleGrantedBy")
  teamMemberRolesRevoked    TeamMemberRole[]           @relation("TeamMemberRoleRevokedBy")
  linkedParticipants        Participant[]              @relation("ParticipantUser")
  requestedChanges          PendingChange[]            @relation("ChangeRequester")
  reviewedChanges           PendingChange[]            @relation("ChangeReviewer")
  changeRequestsRequested   ChangeRequest[]            @relation("ChangeRequestRequester")
  changeRequestsReviewed    ChangeRequest[]            @relation("ChangeRequestReviewer")
  changeRequestsApplied     ChangeRequest[]            @relation("ChangeRequestApplier")
  changeRequestAuditLogs    ChangeRequestAuditLog[]    @relation("ChangeRequestAuditActor")
  participantAuditLogs      ParticipantAuditLog[]      @relation("ParticipantAuditActor")
  changelogEntriesCreated   ChangelogEntry[]           @relation("EntryCreator")
  changelogEntriesResolved  ChangelogEntry[]           @relation("EntryResolver")
  claimedRegistrationTokens RegistrationClaimToken[]   @relation("ClaimedRegistrationTokens")
  claimedParticipantTokens  ParticipantClaimToken[]    @relation("ClaimedParticipantTokens")
  resetSnapshotsCreated     CompetitionResetSnapshot[] @relation("CompetitionResetSnapshotCreator")
  auditEventsCreated        AuditEvent[]               @relation("AuditEventActor")

  @@map("users")
}

// ==================== TENANT ROLE ====================

model TenantRole {
  id        String   @id @default(cuid())
  role      Role
  createdAt DateTime @default(now())

  // Relations
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId, role])
  @@index([tenantId, role])
  @@map("tenant_roles")
}

// ==================== COMPETITION ====================

model Competition {
  id                                String               @id @default(cuid())
  name                              String
  year                              Int
  date                              DateTime?
  dateEnd                           DateTime?
  registrationDeadline              DateTime?
  claimTokenExpiryMode              ClaimTokenExpiryMode @default(COMPETITION_END)
  claimTokenTtlDays                 Int                  @default(7)
  teamOwnerFilterVisibleForTeamchef Boolean              @default(false)
  participantsCanViewAllTeams       Boolean              @default(false)
  spectatorsCanViewAllTeams         Boolean              @default(false)
  marketplaceGlobalVisibility       MarketplaceGlobalVisibility @default(SELECTIVE)
  registrationNotificationEmail     String?
  shirtOrderDeadline                DateTime?
  status                            CompetitionStatus    @default(DRAFT)
  maxTeams                          Int?
  teamSize                          Int                  @default(5)
  ageReferenceDate                  DateTime?
  benchPressTara                    Float                @default(20.0)
  benchPressMode                    BenchPressMode       @default(GROSS)
  stockShotsCount                   Int                  @default(11)
  stockStrikeoutCount               Int                  @default(1)
  location                          String?
  publicResults                     Boolean              @default(true)
  createdAt                         DateTime             @default(now())
  updatedAt                         DateTime             @updatedAt

  // Relations
  tenantId        String
  tenant          Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teams           Team[]
  disciplines     Discipline[]
  classifications Classification[]
  changeRequests ChangeRequest[]
  resetSnapshots  CompetitionResetSnapshot[]
  auditEvents     AuditEvent[]

  @@index([tenantId, status, year, createdAt])
  @@index([status, year, createdAt])
  @@map("competitions")
}

// ==================== TEAM ====================

model Team {
  id                   String               @id @default(cuid())
  name                 String
  contactName          String?
  contactEmail         String?
  contactPhone         String?
  clubName             String?
  notes                String?
  teamPublicationLevel TeamPublicationLevel @default(TEAM_ANONYM)
  registrationMode     TeamRegistrationMode @default(TEAM)
  marketplaceVisibility MarketplaceVisibility @default(ADMIN_MANAGEMENT_ONLY)
  marketplaceStatus    MarketplaceStatus    @default(NEW)
  marketplaceMessage   String?
  approved             Boolean              @default(false)
  totalAge             Int?
  classificationCode   String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  deletedAt            DateTime?

  // Relations
  competitionId           String
  competition             Competition              @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  ownerId                 String
  owner                   User                     @relation("TeamOwner", fields: [ownerId], references: [id])
  teamChiefId             String?
  teamChief               User?                    @relation("TeamChief", fields: [teamChiefId], references: [id])
  memberRoles             TeamMemberRole[]
  participants            Participant[]
  rankings                CompetitionRanking[]
  registrationClaimTokens RegistrationClaimToken[]

  @@index([competitionId, deletedAt])
  @@index([ownerId, deletedAt])
  @@index([teamChiefId, deletedAt])
  @@index([registrationMode, marketplaceStatus])
  @@index([marketplaceVisibility])
  @@index([contactEmail])
  @@index([updatedAt])
  @@map("teams")
}

model TeamMemberRole {
  id        String             @id @default(cuid())
  role      TeamMemberRoleType @default(TEAM_MANAGER)
  reason    String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  revokedAt DateTime?

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("TeamMemberRoleUser", fields: [userId], references: [id], onDelete: Cascade)

  grantedByUserId String?
  grantedByUser   User?   @relation("TeamMemberRoleGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)

  revokedByUserId String?
  revokedByUser   User?   @relation("TeamMemberRoleRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  @@unique([teamId, userId, role])
  @@index([userId, role, revokedAt])
  @@index([teamId, role, revokedAt])
  @@map("team_member_roles")
}

model RegistrationClaimToken {
  id             String    @id @default(cuid())
  tokenHash      String    @unique
  suggestedEmail String
  suggestedName  String?
  createdAt      DateTime  @default(now())
  expiresAt      DateTime
  claimedAt      DateTime?
  revokedAt      DateTime?

  teamId          String
  team            Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  claimedByUserId String?
  claimedByUser   User?   @relation("ClaimedRegistrationTokens", fields: [claimedByUserId], references: [id])

  @@index([teamId])
  @@index([suggestedEmail])
  @@map("registration_claim_tokens")
}

model RegistrationClaimAuditEvent {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  eventType    String
  outcome      String?
  reason       String?
  suspicious   Boolean  @default(false)
  ipAddress    String?
  userAgent    String?
  sessionEmail String?
  tokenId      String?
  teamId       String?
  userId       String?

  @@index([createdAt])
  @@index([tokenId])
  @@index([teamId])
  @@index([ipAddress])
  @@index([suspicious])
  @@map("registration_claim_audit_events")
}

model ParticipantClaimToken {
  id             String    @id @default(cuid())
  tokenHash      String    @unique
  suggestedEmail String
  suggestedName  String?
  createdAt      DateTime  @default(now())
  expiresAt      DateTime
  claimedAt      DateTime?
  revokedAt      DateTime?

  participantId   String
  participant     Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  claimedByUserId String?
  claimedByUser   User?       @relation("ClaimedParticipantTokens", fields: [claimedByUserId], references: [id])

  @@index([participantId])
  @@index([suggestedEmail])
  @@map("participant_claim_tokens")
}

model ParticipantClaimAuditEvent {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  eventType     String
  outcome       String?
  reason        String?
  suspicious    Boolean  @default(false)
  ipAddress     String?
  userAgent     String?
  sessionEmail  String?
  tokenId       String?
  participantId String?
  teamId        String?
  userId        String?

  @@index([createdAt])
  @@index([tokenId])
  @@index([participantId])
  @@index([teamId])
  @@index([ipAddress])
  @@index([suspicious])
  @@map("participant_claim_audit_events")
}

// ==================== PARTICIPANT ====================

model Participant {
  id                               String                           @id @default(cuid())
  firstName                        String
  lastName                         String
  birthYear                        Int
  gender                           Gender
  disciplineCode                   DisciplineAssignment             @default(TBD)
  marketplaceReturnTeamId          String?
  marketplaceReturnDisciplineCode  DisciplineAssignment?
  participantPublicationPreference ParticipantPublicationPreference @default(NAME_VERBERGEN)
  shirtSize                        ShirtSize?
  moderationNote                   String?
  consentGiven                     Boolean                          @default(false)
  email                            String?
  phone                            String?
  overallRank                      Int?
  overallPoints                    Int?
  createdAt                        DateTime                         @default(now())
  updatedAt                        DateTime                         @updatedAt
  deletedAt                        DateTime?

  // Relations
  userId         String?
  user           User?                   @relation("ParticipantUser", fields: [userId], references: [id], onDelete: SetNull)
  teamId         String
  team           Team                    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  claimTokens    ParticipantClaimToken[]
  results        DisciplineResult[]
  pendingChanges PendingChange[]
  auditLogs      ParticipantAuditLog[]

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([teamId, deletedAt])
  @@index([marketplaceReturnTeamId])
  @@index([lastName, firstName])
  @@map("participants")
}

// ==================== DISCIPLINE ====================

model Discipline {
  id        String         @id @default(cuid())
  code      DisciplineCode
  name      String
  unit      String
  sortOrder SortOrder
  type      DisciplineType

  // Relations
  competitionId String
  competition   Competition        @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  results       DisciplineResult[]

  @@unique([competitionId, code])
  @@map("disciplines")
}

// ==================== DISCIPLINE RESULT ====================

model DisciplineResult {
  id        String   @id @default(cuid())
  rawValue  Float?
  rank      Int?
  points    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  disciplineId  String
  discipline    Discipline  @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  shots         Shot[]

  @@unique([disciplineId, participantId])
  @@index([participantId])
  @@map("discipline_results")
}

// ==================== SHOT (Stockschießen) ====================

model Shot {
  id          String  @id @default(cuid())
  shotNumber  Int
  value       Int
  isStrikeout Boolean @default(false)

  // Relations
  resultId String
  result   DisciplineResult @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@unique([resultId, shotNumber])
  @@map("shots")
}

// ==================== CLASSIFICATION ====================

model Classification {
  id                String             @id @default(cuid())
  code              String
  name              String
  type              ClassificationType
  minAge            Int?
  maxAge            Int?
  genderRestriction GenderRestriction?
  sourceClassCodes  String[]

  // Relations
  competitionId String
  competition   Competition          @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  rankings      CompetitionRanking[]

  @@unique([competitionId, code])
  @@map("classifications")
}

// ==================== COMPETITION RANKING ====================

model CompetitionRanking {
  id          String @id @default(cuid())
  totalPoints Int    @default(0)
  rank        Int    @default(0)

  // Relations
  classificationId String
  classification   Classification @relation(fields: [classificationId], references: [id], onDelete: Cascade)
  teamId           String
  team             Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([classificationId, teamId])
  @@index([teamId])
  @@map("competition_rankings")
}

// ==================== PENDING CHANGE (Approval-Workflow) ====================

model PendingChange {
  id            String         @id @default(cuid())
  changeData    String
  beforeData    String?
  status        ApprovalStatus @default(DRAFT)
  bundleId      String?
  bundleType    PendingChangeBundleType?
  bundleStatus  PendingChangeBundleStatus?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  reviewedAt    DateTime?
  reviewComment String?

  // Relations
  participantId String
  participant   Participant           @relation(fields: [participantId], references: [id], onDelete: Cascade)
  requestedById String
  requestedBy   User                  @relation("ChangeRequester", fields: [requestedById], references: [id])
  reviewedById  String?
  reviewedBy    User?                 @relation("ChangeReviewer", fields: [reviewedById], references: [id])
  auditLogs     ParticipantAuditLog[]

  @@index([status, updatedAt])
  @@index([participantId, status])
  @@index([requestedById, status])
  @@index([bundleId])
  @@index([bundleStatus, updatedAt])
  @@map("pending_changes")
}

model ParticipantAuditLog {
  id         String                 @id @default(cuid())
  action     ParticipantAuditAction
  beforeData String?
  afterData  String?
  message    String?
  createdAt  DateTime               @default(now())

  participantId   String
  participant     Participant    @relation(fields: [participantId], references: [id], onDelete: Cascade)
  actorId         String?
  actor           User?          @relation("ParticipantAuditActor", fields: [actorId], references: [id])
  pendingChangeId String?
  pendingChange   PendingChange? @relation(fields: [pendingChangeId], references: [id], onDelete: SetNull)

  @@index([participantId, createdAt])
  @@index([pendingChangeId])
  @@map("participant_audit_logs")
}

// ==================== GENERIC CHANGE REQUEST (Approval-Workflow v2) ====================

model ChangeRequest {
  id                String                  @id @default(cuid())
  targetType        ChangeRequestTargetType
  targetId          String
  changeType        ChangeRequestChangeType @default(UPDATE)
  status            ChangeRequestStatus     @default(DRAFT)
  source            ChangeRequestSource     @default(SELF_SERVICE)
  beforeSnapshot    Json?
  requestedSnapshot Json
  metadata          Json?
  priority          Int                     @default(0)
  reviewComment     String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  submittedAt       DateTime?
  reviewedAt        DateTime?
  appliedAt         DateTime?

  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  competitionId String?
  competition   Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)

  requestedById String
  requestedBy   User    @relation("ChangeRequestRequester", fields: [requestedById], references: [id])
  reviewedById  String?
  reviewedBy    User?   @relation("ChangeRequestReviewer", fields: [reviewedById], references: [id])
  appliedById   String?
  appliedBy     User?   @relation("ChangeRequestApplier", fields: [appliedById], references: [id])

  supersedesRequestId String?
  supersedesRequest   ChangeRequest?  @relation("ChangeRequestSupersession", fields: [supersedesRequestId], references: [id], onDelete: SetNull)
  supersededBy        ChangeRequest[] @relation("ChangeRequestSupersession")

  auditLogs ChangeRequestAuditLog[]

  @@index([tenantId, status, updatedAt])
  @@index([competitionId, status, updatedAt])
  @@index([targetType, targetId, status])
  @@index([requestedById, status])
  @@index([reviewedById, status])
  @@map("change_requests")
}

model ChangeRequestAuditLog {
  id         String                   @id @default(cuid())
  action     ChangeRequestAuditAction
  beforeData Json?
  afterData  Json?
  message    String?
  createdAt  DateTime                 @default(now())

  changeRequestId String
  changeRequest   ChangeRequest @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)
  actorId         String?
  actor           User?         @relation("ChangeRequestAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([changeRequestId, createdAt])
  @@index([actorId, createdAt])
  @@map("change_request_audit_logs")
}

model CompetitionResetSnapshot {
  id        String   @id @default(cuid())
  reason    String
  summary   Json
  snapshot  Json
  createdAt DateTime @default(now())

  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  createdById   String?
  createdBy     User?       @relation("CompetitionResetSnapshotCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([competitionId, createdAt])
  @@map("competition_reset_snapshots")
}

model AuditEvent {
  id         String   @id @default(cuid())
  action     String
  scopeType  String
  scopeId    String
  entityType String?
  entityId   String?
  reason     String?
  beforeData Json?
  afterData  Json?
  meta       Json?
  createdAt  DateTime @default(now())

  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  competitionId String?
  competition   Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  actorId       String?
  actor         User?        @relation("AuditEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([competitionId, createdAt])
  @@index([scopeType, scopeId, createdAt])
  @@index([action, createdAt])
  @@map("audit_events")
}

// ==================== CHANGELOG ENTRY ====================

model ChangelogEntry {
  id          String               @id @default(cuid())
  type        ChangelogEntryType
  status      ChangelogEntryStatus @default(OPEN)
  description String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  resolvedAt  DateTime?

  createdById String
  createdBy   User   @relation("EntryCreator", fields: [createdById], references: [id], onDelete: Cascade)

  resolvedById String?
  resolvedBy   User?   @relation("EntryResolver", fields: [resolvedById], references: [id])

  @@index([status])
  @@index([type])
  @@map("changelog_entries")
}
